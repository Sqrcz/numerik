{
  "name": "sqrcz/numerik",
  "description": "Modern PHP 8.2+ library for validating and parsing Polish identification numbers (PESEL, NIP, REGON, KRS).",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "pesel",
    "nip",
    "regon",
    "krs",
    "poland",
    "polish",
    "validator",
    "validation",
    "numerik"
  ],
  "authors": [
    {
      "name": "Sqrcz",
      "role": "Developer",
      "homepage": "https://github.com/Sqrcz"
    }
  ],
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "friendsofphp/php-cs-fixer": "^3.0",
    "infection/infection": "^0.29"
  },
  "autoload": {
    "psr-4": {
      "SlashLab\\Numerik\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SlashLab\\Numerik\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml",
    "test:cover": "phpunit --configuration phpunit.xml --coverage-html coverage/html --coverage-clover coverage/clover.xml",
    "stan": "phpstan analyse --memory-limit=512M",
    "cs-fix": "php-cs-fixer fix",
    "cs-check": "php-cs-fixer fix --dry-run --diff",
    "mutation": "infection --min-msi=85 --min-covered-msi=90",
    "check": [
      "@cs-check",
      "@stan",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "infection/extension-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
